{
  "name": "@fimbul-works/seidr",
  "description": "Zero-dependency reactive framework with fine-grained reactivity, SSR support, and tiny footprint",
  "version": "1.0.0",
  "type": "module",
  "private": false,
  "license": "MIT",
  "author": "FimbulWorks <contact@fimbul.works>",
  "homepage": "https://github.com/fimbul-works/seidr#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fimbul-works/seidr.git"
  },
  "bugs": {
    "url": "https://github.com/fimbul-works/seidr/issues"
  },
  "keywords": [
    "frontend",
    "dom",
    "reactive",
    "reactive-programming",
    "observables",
    "signals",
    "fine-grained-reactivity",
    "functional",
    "typescript",
    "ui",
    "framework",
    "components",
    "ssr",
    "server-side-rendering",
    "lightweight",
    "zero-dependencies",
    "virtual-dom-free"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ssr": {
      "types": "./dist/index.ssr.d.ts",
      "import": "./dist/index.ssr.js"
    },
    "./html": {
      "types": "./dist/elements/index.d.ts",
      "import": "./dist/elements/index.js",
      "require": "./dist/elements/index.cjs"
    },
    "./testing": {
      "types": "./dist/test-setup/index.d.ts",
      "import": "./dist/test-setup/index.js"
    },
    "./build": {
      "types": "./dist/build-plugins/index.d.ts",
      "import": "./dist/build-plugins/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "bundles/*.js",
    "bundles/*.cjs",
    "bundles/*.d.ts",
    "bundles/*.d.cts",
    "README.md",
    "LICENSE",
    "docs/*.md",
    "seidr-logo.svg"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "clean:dist": "rm -rf dist && rm -rf bundles",
    "clean:examples": "rm -rf examples/build",
    "clean": "pnpm clean:dist && pnpm clean:examples",
    "build": "pnpm build:lib && pnpm build:bundles",
    "build:lib": "tsc",
    "build:bundles": "tsdown --config-loader unrun",
    "build:examples": "pnpm clean:examples && ./build-examples.sh",
    "build:all": "pnpm clean && pnpm build && pnpm build:examples && pnpm sizes",
    "dev": "vite --config vite.examples.config.ts",
    "dev:ssr": "tsx watch examples/ssr/server.ts",
    "test": "vitest run",
    "format": "npx biome format --write src *.json *.ts",
    "sizes": "./calculate-bundle-sizes.sh",
    "prepublishOnly": "pnpm clean:dist && pnpm build"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "dependencies": {
    "@fimbul-works/futhark": "^1.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/express": "^5.0.6",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "express": "^5.2.1",
    "jsdom": "^29.1.0",
    "magic-string": "^0.30.21",
    "oxc-parser": "^0.128.0",
    "rolldown": "1.0.0-rc.17",
    "rollup": "^4.60.2",
    "sirv": "^3.0.2",
    "terser": "^5.46.2",
    "tsdown": "^0.21.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
