{
  "name": "@fimbul-works/seidr",
  "description": "Zero-dependency reactive framework with fine-grained reactivity, SSR support, and tiny footprint",
  "version": "1.0.0",
  "type": "module",
  "private": false,
  "license": "MIT",
  "author": "FimbulWorks <contact@fimbul.works>",
  "homepage": "https://github.com/fimbul-works/seidr#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fimbul-works/seidr.git"
  },
  "bugs": {
    "url": "https://github.com/fimbul-works/seidr/issues"
  },
  "keywords": [
    "frontend",
    "dom",
    "reactive",
    "reactive-programming",
    "observables",
    "signals",
    "fine-grained-reactivity",
    "functional",
    "typescript",
    "ui",
    "framework",
    "components",
    "ssr",
    "server-side-rendering",
    "lightweight",
    "zero-dependencies",
    "virtual-dom-free"
  ],
  "types": "./dist/seidr.d.ts",
  "exports": {
    ".": {
      "types": "./dist/seidr.d.ts",
      "node": {
        "import": "./dist/seidr.server.js",
        "require": "./dist/seidr.server.cjs"
      },
      "browser": {
        "import": "./dist/seidr.js",
        "require": "./dist/seidr.cjs"
      },
      "default": {
        "import": "./dist/seidr.js",
        "require": "./dist/seidr.cjs"
      }
    },
    "./core": {
      "types": "./dist/seidr.core.d.ts",
      "import": "./dist/seidr.core.js",
      "require": "./dist/seidr.core.cjs"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "require": "./dist/testing.cjs"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.cjs",
    "dist/**/*.d.ts",
    "dist/**/*.map",
    "seidr-logo.svg",
    "README.md",
    "docs/*.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "clean:dist": "rm -rf dist && rm -rf build",
    "clean:examples": "rm -rf examples/dist",
    "clean": "pnpm clean:dist && pnpm clean:examples",
    "build": "pnpm clean:dist && concurrently \"pnpm build:javascript\" \"pnpm build:types\"",
    "build:javascript": "NODE_OPTIONS=\"--max-old-space-size=4096\" rollup -c rollup.config.js",
    "build:types-raw": "tsc -p tsconfig.declarations.json",
    "build:types": "pnpm build:types-raw && tsx scripts/build-dts.ts",
    "build:examples": "pnpm clean:examples && ./build-examples.sh",
    "build:all": "pnpm clean && pnpm build && pnpm build:examples && pnpm sizes",
    "sizes": "./calculate-bundle-sizes.sh",
    "dev:examples": "vite --config vite.examples.config.ts",
    "dev:ssr": "tsx watch examples/ssr/server.ts",
    "format": "npx biome format --write src examples *.json",
    "test": "vitest run",
    "test:ssr:inspect": "npx tsx examples/ssr/inspect.ts",
    "prepublishOnly": "pnpm clean:dist && pnpm build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@testing-library/dom": "^10.4.1",
    "@types/express": "^5.0.6",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "dts-bundle-generator": "^9.5.1",
    "express": "^5.2.1",
    "front-matter": "^4.0.2",
    "jsdom": "^29.0.1",
    "marked": "^17.0.5",
    "puppeteer": "^24.40.0",
    "rollup": "^4.60.1",
    "rollup-plugin-esbuild": "^6.2.1",
    "sirv": "^3.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.2"
  }
}
